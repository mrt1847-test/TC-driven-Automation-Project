{
  "appId": "com.tcautomation.studio",
  "productName": "TC Automation Studio",
  "electronVersion": "33.4.11",
  "asar": true,
  "directories": {
    "output": "release"
  },
  "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
  "files": [
    "out/**/*",
    "package.json"
  ],
  "win": {
    "signAndEditExecutable": false,
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  },
  "extraResources": [
    {
      "from": "../worker",
      "to": "worker",
      "filter": [
        "worker/**/*",
        "requirements.txt",
        "pyproject.toml",
        "!**/__pycache__/**",
        "!**/.pytest_cache/**",
        "!**/*.pyc",
        "!tests/**"
      ]
    },
    {
      "from": "../../runtime-staging",
      "to": "runtime",
      "filter": ["**/*"]
    }
  ]
}
