{
  "name": "tc-automation-studio",
  "version": "0.1.0",
  "private": true,
  "description": "TC-driven Automation Project Studio",
  "scripts": {
    "dev": "concurrently \"npm run dev:worker\" \"npm run dev:desktop\"",
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "dev:worker": "cd apps/worker && python -m uvicorn worker.main:app --reload --host 127.0.0.1 --port 8765",
    "build": "npm run build --workspace=apps/desktop",
    "pack:win": "npm run pack:win --workspace=apps/desktop",
    "dist:win": "npm run dist:win --workspace=apps/desktop",
    "install:worker": "cd apps/worker && pip install -r requirements.txt",
    "e2e:cli-standalone": "cd apps/worker && python -m pytest tests/e2e/test_cli_standalone.py -v",
    "e2e:import": "cd apps/worker && python -m pytest tests/e2e/test_tc_import.py -v",
    "e2e:import:live": "python scripts/e2e_tc_import.py",
    "e2e:generate-raw": "cd apps/worker && python -m pytest tests/e2e/test_generate_raw.py -v",
    "e2e:generate-raw:live": "python scripts/e2e_generate_raw.py",
    "e2e:structure": "cd apps/worker && python -m pytest tests/e2e/test_structure.py -v",
    "e2e:structure:live": "python scripts/e2e_structure.py",
    "e2e:generation": "cd apps/worker && python -m pytest tests/e2e/test_generation.py -v",
    "e2e:generation:live": "python scripts/e2e_generation.py",
    "e2e:runner": "cd apps/worker && python -m pytest tests/e2e/test_runner.py -v",
    "e2e:runner:live": "python scripts/e2e_runner.py",
    "e2e:export": "cd apps/worker && python -m pytest tests/e2e/test_export.py -v",
    "e2e:export:live": "python scripts/e2e_export.py",
    "e2e:reverse-handoff": "cd apps/worker && python -m pytest tests/e2e/test_reverse_handoff.py -v",
    "e2e:reverse-handoff:live": "python scripts/e2e_reverse_handoff.py",
    "e2e:self-healing": "cd apps/worker && python -m pytest tests/e2e/test_self_healing.py -v",
    "e2e:self-healing:live": "python scripts/e2e_self_healing.py",
    "e2e:mvp1": "cd apps/worker && python -m pytest tests/e2e/test_mvp1_gate.py -v",
    "e2e:mvp1:live": "python scripts/e2e_mvp1_gate.py",
    "e2e:mvp2": "cd apps/worker && python -m pytest tests/e2e/test_mvp2_gate.py -v",
    "e2e:mvp2:live": "python scripts/e2e_mvp2_gate.py",
    "e2e:mvp3": "cd apps/worker && python -m pytest tests/e2e/test_mvp3_gate.py -v",
    "e2e:mvp3:live": "python scripts/e2e_mvp3_gate.py",
    "e2e:mvp4": "cd apps/worker && python -m pytest tests/e2e/test_mvp4_gate.py -v",
    "e2e:mvp4:live": "python scripts/e2e_mvp4_gate.py",
    "e2e:smoke": "cd apps/worker && python -m pytest tests/e2e/test_smoke.py -v",
    "e2e:smoke:live": "python scripts/e2e_smoke.py"
  },
  "workspaces": [
    "apps/desktop"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
